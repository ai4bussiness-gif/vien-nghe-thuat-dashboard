---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import AnnouncementBar from '../components/AnnouncementBar.astro';
import EventTimeline from '../components/EventTimeline.astro';
import SpaceCalendar from '../components/SpaceCalendar.astro';

const announcements = [];
---

<Layout>
  <Header
    title="Dashboard Viện Nghệ Thuật"
    subtitle="Cập nhật hoạt động các trung tâm"
  />
  <main class="max-w-6xl mx-auto px-4 sm:px-6 pb-12">
    <AnnouncementBar announcements={announcements} />

    <section id="events" class="scroll-mt-20">
      <div class="flex items-center gap-3 mt-6 mb-4">
        <div class="w-1 h-6 bg-indigo-500 rounded-full"></div>
        <h2 class="text-lg font-bold text-gray-800 dark:text-gray-100">Sự kiện & Lịch họp</h2>
      </div>
      <EventTimeline />
    </section>

    <section id="spaces" class="scroll-mt-20">
      <div class="flex items-center gap-3 mt-10 mb-4">
        <div class="w-1 h-6 bg-emerald-500 rounded-full"></div>
        <h2 class="text-lg font-bold text-gray-800 dark:text-gray-100">Không gian Viện</h2>
      </div>
      <SpaceCalendar />
    </section>
  </main>
</Layout>

---
import type { SpaceBooking } from '../data/spaces';

interface Props {
  booking: SpaceBooking;
  centerColor: string;
}

const { booking, centerColor } = Astro.props;
const isPending = booking.status === 'pending';
---

<div
  class="rounded p-2 text-xs h-full"
  style={`background-color: ${centerColor}18; border-left: 3px solid ${centerColor}`}
>
  <p class="font-semibold text-gray-800 leading-snug line-clamp-2">{booking.title}</p>
  <p class="mt-0.5 font-medium" style={`color: ${centerColor}`}>{booking.center}</p>
  <p class="text-gray-500 mt-0.5">{booking.startTime}–{booking.endTime}</p>
  <span
    class={`inline-block mt-1 px-1.5 py-0.5 rounded-full text-[10px] font-medium ${
      isPending ? 'bg-yellow-100 text-yellow-700' : 'bg-green-100 text-green-700'
    }`}
  >
    {isPending ? 'Chờ duyệt' : 'Đã duyệt'}
  </span>
</div>

---
import type { ResearchProject } from '../data/research';
import { centerColors } from '../data/research';

export interface Props {
  project: ResearchProject;
}

const { project } = Astro.props;
const cc = centerColors[project.leadCenter];

const statusStyles: Record<string, string> = {
  'Đang thực hiện': 'bg-blue-100 text-blue-700 dark:bg-blue-900/30 dark:text-blue-300',
  'Hoàn thành': 'bg-green-100 text-green-700 dark:bg-green-900/30 dark:text-green-300',
  'Đề xuất': 'bg-purple-100 text-purple-700 dark:bg-purple-900/30 dark:text-purple-300',
};

const progressColor = project.progress >= 100
  ? 'bg-green-500'
  : project.progress >= 60
    ? 'bg-blue-500'
    : 'bg-amber-500';
---

<div
  class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 shadow-sm hover:shadow-md hover:border-gray-300 dark:hover:border-gray-500 hover:-translate-y-0.5 transition-all duration-200 overflow-hidden cursor-pointer"
  data-project={project.id}
  data-center={project.leadCenter}
>
  <div class="p-5 space-y-4">
    <!-- Header: badge + status -->
    <div class="flex items-start justify-between gap-3">
      <div class="flex items-center gap-2">
        <span
          class="inline-block px-2.5 py-0.5 rounded-full text-xs font-medium"
          style={`background-color: ${cc.hex}18; color: ${cc.hex};`}
        >
          {project.leadCenter}
        </span>
      </div>
      <span class={`inline-block px-2.5 py-0.5 rounded-full text-xs font-medium flex-shrink-0 ${statusStyles[project.status]}`}>
        {project.status}
      </span>
    </div>

    <!-- Title -->
    <h3 class="text-base font-semibold text-gray-900 dark:text-white leading-snug">
      {project.title}
    </h3>

    <!-- Collaborating centers -->
    {project.collaboratingCenters.length > 0 && (
      <div class="flex flex-wrap items-center gap-1.5 text-xs text-gray-500 dark:text-gray-400">
        <span class="text-gray-400 dark:text-gray-500">Phối hợp:</span>
        {project.collaboratingCenters.map((center) => {
          const c = centerColors[center];
          return (
            <span
              class="inline-flex items-center gap-1 px-2 py-0.5 rounded text-xs font-medium"
              style={`background-color: ${c.hex}12; color: ${c.hex};`}
            >
              {center}
            </span>
          );
        })}
      </div>
    )}

    <!-- Duration -->
    <div class="flex items-center gap-1.5 text-xs text-gray-500 dark:text-gray-400">
      <svg class="w-3.5 h-3.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
      </svg>
      {project.period}
    </div>

    <!-- Progress bar -->
    <div>
      <div class="flex items-center justify-between mb-1.5">
        <span class="text-xs text-gray-500 dark:text-gray-400">Tiến độ</span>
        <span class="text-xs font-medium text-gray-600 dark:text-gray-300">{project.progress}%</span>
      </div>
      <div class="w-full h-2 bg-gray-100 dark:bg-gray-700 rounded-full overflow-hidden">
        <div
          class={`h-full rounded-full transition-all duration-500 ${progressColor}`}
          style={`width: ${project.progress}%`}
        ></div>
      </div>
    </div>

    <!-- Short description -->
    <p class="text-sm text-gray-600 dark:text-gray-300 leading-relaxed">
      {project.shortDesc}
    </p>

    <!-- Expandable detail + PDF -->
    <details class="group">
      <summary class="text-xs font-medium text-indigo-600 dark:text-indigo-400 cursor-pointer hover:text-indigo-700 dark:hover:text-indigo-300 transition-colors select-none">
        <span class="group-open:hidden">▸ Xem chi tiết</span>
        <span class="hidden group-open:inline">▾ Thu gọn</span>
      </summary>
      <div class="mt-3 text-sm text-gray-600 dark:text-gray-300 leading-relaxed space-y-2 border-l-2 border-indigo-200 dark:border-indigo-800 pl-4">
        {project.detailedDesc.split('\n').filter(Boolean).map((para) => (
          <p>{para}</p>
        ))}
        {project.pdfUrl && (
          <a
            href={project.pdfUrl}
            class="inline-flex items-center gap-1.5 text-xs font-medium text-indigo-600 dark:text-indigo-400 hover:text-indigo-700 dark:hover:text-indigo-300 transition-colors mt-2"
          >
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z"/>
            </svg>
            📄 Xem kế hoạch chi tiết (PDF)
          </a>
        )}
      </div>
    </details>
  </div>
</div>

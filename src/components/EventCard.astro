---
import type { Event } from '../data/events';

interface Props {
  event: Event;
}

const { event } = Astro.props;

const badgeConfig = {
  event: { label: 'Sự kiện', classes: 'bg-blue-100 text-blue-700' },
  meeting: { label: 'Họp', classes: 'bg-yellow-100 text-yellow-700' },
  class: { label: 'Lớp học', classes: 'bg-purple-100 text-purple-700' },
  deadline: { label: 'Deadline', classes: 'bg-red-100 text-red-700' },
};

const badge = badgeConfig[event.eventType];
const centerInitial = event.center.charAt(0);

function pad(n: number) {
  return n.toString().padStart(2, '0');
}
function formatTime(d: Date) {
  return `${pad(d.getHours())}:${pad(d.getMinutes())}`;
}

const startTime = formatTime(event.startDate);
const endTime = formatTime(event.endDate);
const isSameTime = startTime === endTime;
---

<div
  class="bg-white rounded-lg p-4 border-l-4 shadow-sm hover:shadow-md transition-shadow"
  style={`border-left-color: ${event.centerColor}`}
>
  <div class="flex items-start gap-3">
    <div
      class="flex-shrink-0 w-9 h-9 rounded-full flex items-center justify-center font-bold text-white text-sm"
      style={`background-color: ${event.centerColor}`}
    >
      {centerInitial}
    </div>

    <div class="flex-1 min-w-0">
      <div class="flex items-start justify-between gap-2">
        <h3 class="font-semibold text-gray-900 text-sm leading-snug">{event.title}</h3>
        <span class={`text-xs font-medium px-2 py-0.5 rounded-full flex-shrink-0 ${badge.classes}`}>
          {badge.label}
        </span>
      </div>

      <p class="text-xs text-gray-400 mt-0.5">{event.center}</p>

      <div class="flex flex-wrap items-center gap-x-4 gap-y-1 mt-2 text-xs text-gray-500">
        <span class="flex items-center gap-1">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          {isSameTime ? startTime : `${startTime} – ${endTime}`}
        </span>
        <span class="flex items-center gap-1">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
          {event.location}
        </span>
      </div>

      {event.description && (
        <p class="text-xs text-gray-400 mt-1.5 line-clamp-2">{event.description}</p>
      )}
    </div>
  </div>
</div>

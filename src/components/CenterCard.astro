---
export interface Props {
  name: string;
  description: string;
  color: string;
  colorClass: string;
}

const { name, description, color, colorClass } = Astro.props;
---

<div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 overflow-hidden shadow-sm hover:shadow-md transition-shadow duration-200 group">
  <div
    class="h-40 flex items-center justify-center text-sm text-gray-400 dark:text-gray-500"
    style={`background-color: ${color}1A;`}
  >
    <div class="flex flex-col items-center gap-2">
      <div class="w-12 h-12 rounded-full flex items-center justify-center" style={`background-color: ${color}33;`}>
        <div class="w-6 h-6 rounded-full" style={`background-color: ${color};`}></div>
      </div>
      <span class="text-xs">[Ảnh trung tâm]</span>
    </div>
  </div>
  <div class="p-4">
    <div class="flex items-center gap-2 mb-2">
      <div class="w-3 h-3 rounded-full flex-shrink-0" style={`background-color: ${color};`}></div>
      <h3 class="font-semibold text-gray-900 dark:text-white text-sm">{name}</h3>
    </div>
    <p class="text-xs text-gray-500 dark:text-gray-400 leading-relaxed">{description}</p>
  </div>
</div>

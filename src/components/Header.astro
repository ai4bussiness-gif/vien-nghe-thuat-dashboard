---
export interface Props {
  title: string;
  subtitle?: string;
}

const { title, subtitle } = Astro.props;
---

<header class="bg-white dark:bg-gray-900 border-b border-gray-200 dark:border-gray-800 sticky top-0 z-30 shadow-sm">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="flex items-center justify-between h-16">
      <div class="flex items-center gap-3 min-w-0">
        <img src="/logo-vien.png" alt="Viện Nghệ Thuật" class="w-12 h-12 rounded-lg flex-shrink-0 shadow-sm object-cover bg-white dark:bg-transparent dark:brightness-0 dark:invert" />
        <div class="min-w-0">
          <h1 class="text-base sm:text-lg font-bold text-gray-900 dark:text-white truncate">{title}</h1>
          {subtitle && (
            <p class="text-xs text-gray-500 dark:text-gray-400 hidden sm:block truncate">{subtitle}</p>
          )}
        </div>
      </div>

      <div class="flex items-center gap-1 sm:gap-2">
        <!-- Desktop nav -->
        <nav class="hidden md:flex items-center gap-1 mr-2">
          <a href="#events" class="px-3 py-1.5 text-xs font-medium rounded-full bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-300 hover:bg-emerald-100 dark:hover:bg-emerald-900/40 hover:text-emerald-600 dark:hover:text-emerald-400 transition-colors">
            📅 Sự kiện
          </a>
          <a href="#spaces" class="px-3 py-1.5 text-xs font-medium rounded-full bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-300 hover:bg-indigo-100 dark:hover:bg-indigo-900/40 hover:text-indigo-600 dark:hover:text-indigo-400 transition-colors">
            🏛️ Không gian
          </a>
        </nav>

        <!-- Mobile hamburger (md:hidden) + Dark toggle -->
        <button id="mobile-menu-btn" class="md:hidden p-3 rounded-lg hover:bg-gray-200 dark:hover:bg-gray-700 text-gray-500 dark:text-gray-300 transition-colors active:bg-gray-300 dark:active:bg-gray-600 touch-manipulation" title="Menu" aria-label="Mở menu" style="-webkit-tap-highlight-color: transparent; touch-action: manipulation;">
          <svg id="icon-hamburger" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
          <svg id="icon-close" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>

        <button id="theme-toggle" class="p-2 rounded-lg hover:bg-gray-200 dark:hover:bg-gray-700 text-gray-500 dark:text-gray-300 transition-colors" title="Chuyển giao diện">
          <svg id="icon-sun" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/>
          </svg>
          <svg id="icon-moon" class="w-5 h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/>
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile dropdown menu -->
    <div id="mobile-menu" class="md:hidden hidden border-t border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-900">
      <nav class="flex flex-col gap-1 px-4 py-3">
        <a href="#events" class="block px-3 py-2.5 text-sm font-medium rounded-lg bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-200 hover:bg-emerald-100 dark:hover:bg-emerald-900/40 hover:text-emerald-600 dark:hover:text-emerald-400 transition-colors">
          📅 Sự kiện
        </a>
        <a href="#spaces" class="block px-3 py-2.5 text-sm font-medium rounded-lg text-gray-600 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-800 hover:text-gray-900 dark:hover:text-white transition-colors">
          🏛️ Không gian
        </a>
      </nav>
    </div>
  </div>
</header>

<script is:inline>
(function(){
  function initMobileMenu() {
    var btn = document.getElementById('mobile-menu-btn');
    var menu = document.getElementById('mobile-menu');
    var ih = document.getElementById('icon-hamburger');
    var ic = document.getElementById('icon-close');
    if (!btn || !menu) return;
    btn.addEventListener('click', function(e) {
      e.stopPropagation();
      menu.classList.toggle('hidden');
      if (ih) ih.classList.toggle('hidden');
      if (ic) ic.classList.toggle('hidden');
    });
    menu.querySelectorAll('a').forEach(function(a) {
      a.addEventListener('click', function() {
        menu.classList.add('hidden');
        if (ih) ih.classList.remove('hidden');
        if (ic) ic.classList.add('hidden');
      });
    });
  }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initMobileMenu);
  } else {
    initMobileMenu();
  }
})();
</script>